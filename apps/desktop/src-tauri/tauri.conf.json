{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Learning House",
  "mainBinaryName": "learning-house",
  "version": "0.4.0",
  "identifier": "com.hsiaokang.learninghouse",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyQzlFMzQwMUIwMTY5Q0QKUldUTmFRRWJRT1BKUXNRc1JBN3FEMlMzRVJLNHRLMitXZ2hVVk16OE8rVW5PeTNuNUhpMHErWHcK",
      "endpoints": [
        "https://github.com/HsiaoKang/learning-house/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "Learning House",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
