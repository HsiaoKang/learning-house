{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "主窗口能力：文件对话框、文件读取与目录扫描、本地资源协议、键值存储",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-read-text-file",
    "fs:allow-exists",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "store:default",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }, { "path": "**/.learninghouse" }, { "path": "**/.learninghouse/**" }]
    }
  ]
}
